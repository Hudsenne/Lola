# Backend bind settings
LOLA_BACKEND_HOST=127.0.0.1
LOLA_BACKEND_PORT=8787

# Chat mode: use `mock` for demo handoff without Lobster/OpenClaw.
LOLA_CHAT_MODE=mock

# Optional Lobster workspace for /api/chat when LOLA_CHAT_MODE=lobster.
LOBSTER_WORKSPACE=/home/jm/.lobster_workspace

# Baseline API used by comparison + orchestrator pipeline
LOLA_API_BASE_URL=http://127.0.0.1:8000
LOLA_API_TIMEOUT_MS=5000
